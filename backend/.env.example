# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Customize Model IDs
GEMINI_MODEL=gemini-3.1-flash-lite
IMAGEN_MODEL=gemini-3.1-flash-image-preview

# Google Cloud Platform Configuration (for Cloud Run, local Firestore, GCS)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

# (Optional) Firestore Custom Database ID
FIRESTORE_DATABASE=(default)

# (Optional) Google Cloud Storage Bucket for cached images
# If omitted, the app falls back to base64 Data URLs for local dev ease!
GCS_BUCKET_NAME=your_gcs_bucket_name_here
