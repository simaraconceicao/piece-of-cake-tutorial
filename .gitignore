# Build outputs
# ============================================================
dist/
dist-ssr/
build/

# ============================================================
# Environment & secrets — NEVER commit these
# ============================================================
.env
.env.local
.env.*.local

# Google Cloud service account credentials
*.json.key
service-account*.json
gcp-credentials*.json
*-credentials.json
application_default_credentials.json

# ============================================================
# Logs
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# TypeScript
# ============================================================
*.tsbuildinfo

# ============================================================
